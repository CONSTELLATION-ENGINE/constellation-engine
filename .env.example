# Constellation Engine — Configuration Template
# Copy this to .env and fill in your values. All keys are optional unless marked [REQUIRED].
# Most users should configure providers and ports through the setup wizard / dashboard
# (config.json owns the canonical settings); this file only carries env overrides.
# Timestamps are stored in UTC; display times auto-match your system timezone.

# === LLM Provider ===
# [REQUIRED] At least one provider key is needed for first-run conversation. Other
# providers (OpenAI, Ollama, Gemini, etc.) are configured through the wizard.
ANTHROPIC_API_KEY=your-api-key-here

# === Embedding ===
# Engine ships BGE-M3 (1024-dim) running in-process via @xenova/transformers.
# Most users should leave this alone. Set USE_GPU_EMBEDDING=true only if you have
# a CUDA / MPS-capable runtime and have read scripts/mimir-js/README.
USE_GPU_EMBEDDING=false

# === Display & Localization ===
# Timezone for diary entries and cron window calculations.
# Auto-detected from the system on first run; override here only if needed.
TZ_DISPLAY=UTC

# === Server ===
# Dashboard port (the engine binds 127.0.0.1 by default; do NOT expose it
# publicly without putting a TLS-terminating reverse proxy in front).
# This env override is read by config.json migration; canonical value lives there.
ENGINE_DASHBOARD_PORT=18800
ENGINE_MIMIR_PORT=18810

# === Database ===
# Directory where local SQLite files live (created on first run).
# Defaults to <userData>/Constellation/engine/ on packaged installs.
DATA_DIR=./data
# Enable verbose SQL query logging (debug only).
DEBUG_SQL=false

# === Memory Management ===
# Auto-purge old debug / status logs (in days; 0 = never).
# Note: conversations and star-map nodes are NEVER auto-purged.
DEBUG_LOG_RETENTION_DAYS=7

# === Cold-Start Bootstrap ===
# Drift threshold for the cold-start seed-vs-pool similarity gate. 0.85 means
# new seeds must be ≥0.85 cosine-similar to the existing pool to refine in;
# leave unset to inherit the engine default.
# MIMIR_BOOTSTRAP_DRIFT_THRESHOLD=0.85

# === Multi-Language (deferred) ===
# When non-empty, dashboard accepts the `lang` body hint on /api/chat and
# instructs the model to respond in that language. Off by default in OSS;
# multi-language UX ships in a later milestone.
# MULTILANG_ENABLED=

# === Advanced ===
# Project identifier (appears in logs and metrics).
PROJECT_NAME=constellation-engine
