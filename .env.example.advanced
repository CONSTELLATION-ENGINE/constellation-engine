# Advanced Configuration — for expert users only.
# Copy values from here to .env if you need fine-grained control.
# Most projects can skip this file entirely. The model identity for each LLM
# role is owned by config.json (managed via the dashboard Settings panel),
# not by env vars.

# === Embedding Backends ===
# Engine ships BGE-M3 (1024-dim). Do NOT change EMBEDDING_DIM unless you also
# rebuild the vec0 index — schema and stored vectors are 1024-wide.
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIM=1024
EMBEDDING_DEVICE=cpu         # or 'cuda', 'mps' if available

# === Memory Graph Tuning ===
# Edge density: how many references per node on average.
GRAPH_EDGE_DENSITY_TARGET=2.5
# Multi-pass semantic routing: rerank pool size before final selection.
POOL_RERANK_SIZE=50
# Minimum confidence for auto-linking (0.0-1.0; higher = stricter).
SEMANTIC_LINK_THRESHOLD=0.65

# === Mímir Autonomy (paid tier) ===
# These are the env kill-switches for the autonomy substrate. Per-user toggles
# live in config.json and the dashboard Mímir Autonomy panel; setting any of
# these to '0' overrides the user setting and disables the action engine-wide.
# MIMIR_AUTONOMY=                 # set '0' to hard-disable all autonomy
# MIMIR_OUTREACH=                 # set '0' to disable outreach
# MIMIR_FETCH=                    # set '0' to disable external fetch
# MIMIR_PROFILE=                  # set '0' to disable profile self-act
# MIMIR_CURIOSITY=                # set '0' to disable curiosity self-act
# COLD_START_OUTREACH=            # set '0' to disable cold-start outreach loop

# === Performance ===
# Worker thread pool size for embedding / indexing (0 = auto-detect).
WORKER_THREADS=0
# Cache size for compiled regex rules (number of entries).
REGEX_CACHE_SIZE=1000
# HTTP request timeout (milliseconds).
REQUEST_TIMEOUT_MS=30000

# === Observability ===
# Prometheus metrics endpoint (leave empty to disable).
PROMETHEUS_PORT=9090
# Structured logging format: json or text.
LOG_FORMAT=text
# Include request/response bodies in logs (verbose; security risk).
LOG_PAYLOADS=false

# === Advanced Database ===
# Connection pool size (number of concurrent SQLite connections).
DB_POOL_SIZE=5
# WAL mode (write-ahead logging; improves concurrency).
DB_WAL_MODE=true
# Vacuum threshold (run VACUUM after N writes; 0 = disable).
DB_VACUUM_THRESHOLD=10000

# === TLS / Security ===
# Enable HTTPS (requires cert.pem and key.pem in ./certs/).
USE_TLS=false
# Allowed origins for CORS. Default ports match the engine + Mímir embed daemon.
ALLOWED_ORIGINS=localhost:18800,127.0.0.1:18800
